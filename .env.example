# Docker Compose Profiles
# To enable optional services, add them to COMPOSE_PROFILES (comma separated).
# - 'mailpit': Email catcher (Enabled by default)
# - 'tools': phpMyAdmin, Filebrowser
# - 'debug': Dozzle (Live Logs)
# Example: COMPOSE_PROFILES=mailpit,tools,debug
COMPOSE_PROFILES=mailpit

# File Browser Configuration
FILEBROWSER_ADMIN_PASSWORD=admin

# OpenLiteSpeed Configuration
OLS_PASSWORD=admin123
INSTALL_WORDPRESS=true

# SMTP Relay Configuration (Default points to the 'mailpit' tool)
SMTP_SERVER=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SERVER_HOSTNAME=example.com

# Soft Email Overwrite (Optional)
# This replaces sender addresses from local/internal domains (like wordpress@localhost)
# while allowing external domains to pass through untouched.
OVERWRITE_FROM=site-admin@example.com

# AWS SES Tagging
SES_TENANT_TAG=your-tenant-name

# WordPress Cron (Set to true if using Dokploy Scheduler)
DISABLE_WP_CRON=false

# LiteSpeed Cache - Object Cache Configuration
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_MAX_MEMORY=64mb
LITESPEED_CACHE_OBJECT_CONF=true
LITESPEED_CACHE_OBJECT_ENABLE=true
LITESPEED_CACHE_OBJECT_KIND=1

# Performance - Compression
GZIP_ENABLE=1
BROTLI_ENABLE=1

# WordPress Database
WORDPRESS_DB_HOST=mariadb:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=your_db_password
MYSQL_ROOT_PASSWORD=your_root_password
# Enabled by default to ensure system tables stay up to date
MARIADB_AUTO_UPGRADE=1

# PHP Performance & Limits
PHP_MAX_CONNS=35
WORDPRESS_MEMORY_LIMIT=256M
WORDPRESS_UPLOAD_LIMIT=64M
WORDPRESS_MAX_EXECUTION_TIME=300
WORDPRESS_MAX_INPUT_VARS=3000

# Opcache Defaults (Production Optimized)
OPCACHE_ENABLE=1
OPCACHE_MEMORY_CONSUMPTION=256
OPCACHE_INTERNED_STRINGS_BUFFER=8
OPCACHE_MAX_ACCELERATED_FILES=15000
OPCACHE_REVALIDATE_FREQ=300
OPCACHE_FAST_SHUTDOWN=1
