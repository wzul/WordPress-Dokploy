# Database Configuration
WORDPRESS_DB_HOST=wp_db
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change_me_immediately

# PHP & WordPress Configuration
# This single variable controls both the PHP memory_limit and WordPress WP_MEMORY_LIMIT
WORDPRESS_MEMORY_LIMIT=256M
WORDPRESS_CONFIG_EXTRA="define('WP_MEMORY_LIMIT', '256M');\ndefine('DISALLOW_FILE_EDIT', true);"

# PHP-FPM Tuning (dynamic or ondemand)
PHP_FPM_PM=dynamic
PHP_FPM_MAX_CHILDREN=10
PHP_FPM_START_SERVERS=2
PHP_FPM_MIN_SPARE_SERVERS=1
PHP_FPM_MAX_SPARE_SERVERS=3
PHP_FPM_IDLE_TIMEOUT=10s

# OpenLiteSpeed Configuration
OLS_PASSWORD=admin123

# File Manager Configuration
FILE_MANAGER_USER=admin
FILE_MANAGER_PASSWORD=change_me_immediately
FILE_MANAGER_PATH=/file-manager-secret
DB_MANAGER_PATH=/wp-db-admin
ADMINER_DESIGN=pepa-linha

# SMTP Relay Configuration
SMTP_SERVER=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SERVER_HOSTNAME=example.com

# AWS SES Tagging
SES_TENANT_TAG=your-tenant-name
