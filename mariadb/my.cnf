[mysqld]
# --- Core RAM Limits ---
# Optimized for small client sites
innodb_buffer_pool_size         = 16M

# --- Logging & Durability ---
innodb_log_file_size            = 4M
innodb_flush_log_at_trx_commit  = 2

# --- Resource Constraints ---
# Increased to 12 for better stability during traffic spikes
max_connections                 = 12
performance_schema              = OFF

# --- Buffers & Caches ---
key_buffer_size                 = 4M
thread_cache_size               = 2

# --- Temporary Tables ---
tmp_table_size                  = 1M
max_heap_table_size             = 1M

# --- Extra Optimization ---
read_buffer_size                = 256K
read_rnd_buffer_size            = 256K
sort_buffer_size                = 256K
join_buffer_size                = 256K
